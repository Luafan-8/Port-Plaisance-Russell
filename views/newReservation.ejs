<%- include('partials/header') %>

<h1>Nouvelle réservation - Catway <%= catway.catwayNumber %></h1>

<% if (error) { %>
    <p ><%= erreur %></p>
<% } %>

<form method="POST" action="/reservations/catways/<%= catway.catwayNumber %>/reservations">
    
    <label>Nom du client</label>
    <input type="text" name="clientName" required><br><br>

    <label>Nom du bateau</label>
    <input type="text" name="boatName" required><br><br>

    <label>Date début</label>
    <input type="date" name="startDate" required><br><br>

    <label>Date fin</label>
    <input type="date" name="endDate" required><br><br>

    <button type="submit">Créer</button>
</form>

<br>
<a href="/reservations/catways/<%= catway.catwayNumber %>/reservations/view">
    Retour
</a>

<%- include('partials/footer') %>