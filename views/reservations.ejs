<%- include('partials/header') %>

<h1>Réservations</h1>
<a href="/dashboard">Dashboard</a>

<h2>Créer une réservation</h2>

<form action="/reservations" method="POST">
  <select name="catwayNumber" required>
    <% catways.forEach(c => { %>
      <option value="<%= c.catwayNumber %>">
        Catway <%= c.catwayNumber %>
      </option>
    <% }) %>
  </select>

  <input type="text" name="clientName" placeholder="Nom du client" required>
  <input type="text" name="boatName" placeholder="Nom du bateau" required>

  <label>Début :</label>
  <input type="date" name="startDate" required>

  <label>Fin :</label>
  <input type="date" name="endDate" required>

  <button type="submit">Créer</button>
</form>

<h2>Liste des réservations</h2>

<table border="1">
<tr>
  <th>Catway</th>
  <th>Client</th>
  <th>Bateau</th>
  <th>Début</th>
  <th>Fin</th>
  <th>Action</th>
</tr>

<% reservations.forEach(r => { %>
<tr>
  <td><%= r.catwayNumber %></td>
  <td><%= r.clientName %></td>
  <td><%= r.boatName %></td>
  <td><%= r.startDate.toISOString().split('T')[0] %></td>
  <td><%= r.endDate.toISOString().split('T')[0] %></td>
  <td>
    <form action="/reservations/delete/<%= r._id %>" method="POST">
      <button type="submit">Supprimer</button>
    </form>
  </td>
</tr>
<% }) %>

</table>

<%- include('partials/footer') %>